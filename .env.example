# .env.example (committed)
# Database — choose one: postgres | sqlserver | mysql
DB_PROVIDER=postgres
DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=nexus;Username=nexus;Password=your_db_password_here
DB_PASSWORD=your_db_password_here
DB_ROOT_PASSWORD=your_db_root_password_here

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars_at_least
JWT_ISSUER=nexus-api
JWT_AUDIENCE=nexus-client
JWT_EXPIRY_MINUTES=60

# API
ASPNETCORE_ENVIRONMENT=Development
API_PORT=5000

# OpenTelemetry / Zipkin
OTEL_EXPORTER_ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
OTEL_SERVICE_NAME=nexus-api

# Frontend
VITE_API_URL=http://localhost:5000
FRONTEND_PORT=3000

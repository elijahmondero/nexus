{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Order": 1,
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "frontend-route": {
        "ClusterId": "frontend-cluster",
        "Order": 2,
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api-cluster": {
        "Destinations": {
          "api-destination": {
            "Address": "http://api:8080"
          }
        }
      },
      "frontend-cluster": {
        "Destinations": {
          "frontend-destination": {
            "Address": "http://frontend:5173"
          }
        }
      }
    }
  }
}
